<?xml version="1.0" encoding="utf-8"?>
<!--
    Rutas autorizadas para FileProvider.
    P1: fenix_downloads → OTA updates (UpdateChecker.downloadAndInstall)
    P6: fenix_documents → archivos adjuntos seleccionados por el usuario en ChatInputBar
        fenix_cache     → archivos temporales de cámara/captura
-->
<paths>
    <external-files-path name="fenix_downloads" path="Download/" />
    <external-files-path name="fenix_documents" path="Documents/" />
    <cache-path         name="fenix_cache"      path="." />
</paths>
